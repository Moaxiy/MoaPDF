{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MoaPDF",
  "version": "0.1.1",
  "identifier": "com.moaxiy.moapdf",
  "build": {
    "beforeDevCommand": "npm run dev -- --host 127.0.0.1 --port 1420",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "MoaPDF",
        "width": 1280,
        "height": 860,
        "minWidth": 980,
        "minHeight": 680,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "createUpdaterArtifacts": false,
    "windows": {
      "digestAlgorithm": "sha256"
    },
    "icon": [
      "../build/icon.png",
      "../build/icon.ico"
    ]
  }
}
